    "nodes": [
      {
        "id": "wa-webhook-1",
        "name": "WhatsApp Incoming Message",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1.1,
        "position": [
          0,
          300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "restaurant-bot",
          "responseMode": "lastNode",
          "options": {}
        }
      },
      {
        "id": "extract-1",
        "name": "Extract Message Details",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          220,
          300
        ],
        "parameters": {
          "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst entry = body?.entry?.[0];\nconst change = entry?.changes?.[0];\nconst value = change?.value;\nconst msg = value?.messages?.[0];\nconst contact = value?.contacts?.[0];\n\nif (!msg) {\n  return [{ json: { skip: true } }];\n}\n\nconst customerName = contact?.profile?.name || 'Valued Guest';\nconst customerPhone = msg.from;\nconst messageText = msg.text?.body || '';\nconst messageId = msg.id;\nconst phoneNumberId = value?.metadata?.phone_number_id;\n\nreturn [{\n  json: {\n    customerName,\n    customerPhone,\n    messageText,\n    messageId,\n    phoneNumberId,\n    timestamp: new Date().toISOString()\n  }\n}];"
        }
      },
      {
        "id": "skip-check-1",
        "name": "Has Message?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2,
        "position": [
          440,
          300
        ],
        "parameters": {
          "conditions": {
            "options": {
              "caseSensitive": false
            },
            "conditions": [
              {
                "leftValue": "={{ $json.skip }}",
                "rightValue": true,
                "operator": {
                  "type": "boolean",
                  "operation": "notEquals"
                }
              }
            ]
          }
        }
      },
      {
        "id": "ai-classify-1",
        "name": "AI Intent Classifier",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          660,
          200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://openrouter.ai/api/v1/chat/completions",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpHeaderAuth",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "sendBody": true,
          "contentType": "json",
          "body": {
            "model": "google/gemini-flash-1.5",
            "max_tokens": 50,
            "messages": [
              {
                "role": "system",
                "content": "You are an intent classifier for a restaurant WhatsApp bot. Classify the customer message into EXACTLY ONE of these intents: BOOKING, MENU, HOURS, LOCATION, COMPLAINT, GREETING, GENERAL. Reply with ONLY the intent word, nothing else."
              },
              {
                "role": "user",
                "content": "={{ $json.messageText }}"
              }
            ]
          }
        }
      },
      {
        "id": "extract-intent-1",
        "name": "Extract Intent",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          880,
          200
        ],
        "parameters": {
          "jsCode": "const prev = $input.first().json;\nconst intent = prev.choices?.[0]?.message?.content?.trim().toUpperCase() || 'GENERAL';\nconst validIntents = ['BOOKING','MENU','HOURS','LOCATION','COMPLAINT','GREETING','GENERAL'];\nconst finalIntent = validIntents.includes(intent) ? intent : 'GENERAL';\n\n// Carry forward all previous data\nconst data = $('Extract Message Details').first().json;\n\nreturn [{\n  json: {\n    ...data,\n    intent: finalIntent\n  }\n}];"
        }
      },
      {
        "id": "route-1",
        "name": "Route by Intent",
        "type": "n8n-nodes-base.switch",
        "typeVersion": 3,
        "position": [
          1100,
          200
        ],
        "parameters": {
          "mode": "rules",
          "rules": {
            "values": [
              {
                "conditions": {
                  "conditions": [
                    {
                      "leftValue": "={{ $json.intent }}",
                      "rightValue": "BOOKING",
                      "operator": {
                        "type": "string",
                        "operation": "equals"
                      }
                    }
                  ]
                },
                "renameOutput": true,
                "outputKey": "Booking"
              },
              {
                "conditions": {
                  "conditions": [
                    {
                      "leftValue": "={{ $json.intent }}",
                      "rightValue": "MENU",
                      "operator": {
                        "type": "string",
                        "operation": "equals"
                      }
                    }
                  ]
                },
                "renameOutput": true,
                "outputKey": "Menu"
              },
              {
                "conditions": {
                  "conditions": [
                    {
                      "leftValue": "={{ $json.intent }}",
                      "rightValue": "HOURS",
                      "operator": {
                        "type": "string",
                        "operation": "equals"
                      }
                    }
                  ]
                },
                "renameOutput": true,
                "outputKey": "Hours"
              },
              {
                "conditions": {
                  "conditions": [
                    {
                      "leftValue": "={{ $json.intent }}",
                      "rightValue": "COMPLAINT",
                      "operator": {
                        "type": "string",
                        "operation": "equals"
                      }
                    }
                  ]
                },
                "renameOutput": true,
                "outputKey": "Complaint"
              }
            ]
          },
          "fallbackOutput": "extra"
        }
      },
