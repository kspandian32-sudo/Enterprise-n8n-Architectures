# =============================================================
# Enterprise n8n Production Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================

# Global Toggles (Enterprise Resilience Pattern)
# Set to 'true' to bypass dangerous actions (emails, file moves, publishing) 
# and route to SIMULATED NoOp nodes instead.
SAFE_MODE=true

# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# n8n Security
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING
JWT_SECRET=CHANGE_ME_ANOTHER_RANDOM_STRING

# Timezone
TIMEZONE=Asia/Kolkata

# Supabase (Enterprise Memory Layer)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Notifications (Log-Drain Alerting)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# MCP Task Orchestrator
MCP_SPREADSHEET_ID=your-google-spreadsheet-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
MCP_STANDUP_DIR=./standups
