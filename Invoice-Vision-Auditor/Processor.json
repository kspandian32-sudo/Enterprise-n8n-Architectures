      {
        "parameters": {
          "jsCode": "// Get rows from BOTH sheets for duplicate scanning\nconst verifiedRows = $('Read Verified Sheet').all().map(i => i.json).filter(r => r.invoice_number);\nconst flaggedRows = $input.all().map(i => i.json).filter(r => r.invoice_number);\nconst allRows = [...verifiedRows, ...flaggedRows];\n\n// Current invoice being processed\nconst auditData = $('Parse Analysis Result').first().json;\nconst invNum = String(auditData.invoice_number || '').toLowerCase().trim();\nconst vendor = String(auditData.vendor_name || '').toLowerCase().trim();\n\nlet is_duplicate = false;\nlet duplicate_ref = null;\n\nif (invNum.length > 2 && vendor.length > 2) {\n  const match = allRows.find(r =>\n    String(r.invoice_number || '').toLowerCase().trim() === invNum &&\n    String(r.vendor_name || '').toLowerCase().trim() === vendor\n  );\n  if (match) {\n    is_duplicate = true;\n    duplicate_ref = match.file_name || 'previous submission';\n  }\n}\n\nconst errors = [...(auditData.errors || [])];\nif (is_duplicate) errors.push('Possible duplicate of: ' + duplicate_ref);\n\nreturn [{ json: { ...auditData, is_duplicate, duplicate_ref: duplicate_ref || null, errors } }];"
        },
