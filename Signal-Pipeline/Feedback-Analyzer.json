    {
      "parameters": {
        "jsCode": "const stats = $('Analyze Feedback Ratio').item.json;\nconst configItems = $input.all();\nlet currentThreshold = 7.5; // default\n\nfor (const item of configItems) {\n  if (item.json['Configuration Key'] === 'Confidence Threshold') {\n    currentThreshold = parseFloat(item.json['Configuration Value']) || 7.5;\n  }\n}\n\nif (currentThreshold < 1) currentThreshold = currentThreshold * 10;\n\nlet newThreshold = currentThreshold + stats.adjustment;\nif (newThreshold > 9) newThreshold = 9;\nif (newThreshold < 5) newThreshold = 5;\n\nreturn [{ \n  json: { \n    'Configuration Key': 'Confidence Threshold', \n    'Configuration Value': newThreshold,\n    oldValue: currentThreshold,\n    stats \n  }\n}];"
      },
