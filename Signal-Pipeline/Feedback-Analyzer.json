    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) return [{ json: { decision: 'No feedback data', newThreshold: null } }];\n\nlet relevantCount = 0;\nlet irrelevantCount = 0;\n\nitems.forEach(item => {\n  const feedback = (item.json['User Feedback'] || '').toLowerCase().trim();\n  if (feedback === 'relevant') relevantCount++;\n  if (feedback === 'irrelevant') irrelevantCount++;\n});\n\nconst totalFeedback = relevantCount + irrelevantCount;\nif (totalFeedback < 5) return [{ json: { decision: 'Not enough feedback data', totalFeedback, newThreshold: null } }];\n\nconst accuracy = relevantCount / totalFeedback;\nlet adjustment = 0;\nif (accuracy < 0.5) adjustment = 0.5; // tighten threshold (requires higher score)\nelse if (accuracy > 0.8) adjustment = -0.5; // loosen threshold\n\nreturn [{ json: { accuracy, relevantCount, irrelevantCount, totalFeedback, adjustment } }];"
      },
      "id": "b42676bd-514c-495c-8e75-f479def939e9",
