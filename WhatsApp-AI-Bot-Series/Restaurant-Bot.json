      {
        "id": "format-reply-1",
        "name": "Format Final Reply",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1560,
          300
        ],
        "parameters": {
          "jsCode": "// Get reply text from whichever branch ran\nlet replyText = '';\nconst branches = ['Generate Booking Reply','Generate Menu Reply','Generate Hours Reply','Generate Complaint Reply','Generate General Reply'];\n\nfor (const branch of branches) {\n  try {\n    const result = $(branch).first().json;\n    if (result?.choices?.[0]?.message?.content) {\n      replyText = result.choices[0].message.content.trim();\n      break;\n    }\n  } catch(e) {}\n}\n\nif (!replyText) replyText = 'Thank you for contacting us! We will get back to you shortly. ðŸ™';\n\nconst msgData = $('Extract Message Details').first().json;\n\nreturn [{\n  json: {\n    customerPhone: msgData.customerPhone,\n    customerName: msgData.customerName,\n    phoneNumberId: msgData.phoneNumberId,\n    originalMessage: msgData.messageText,\n    intent: $('Extract Intent').first().json.intent,\n    replyText,\n    timestamp: msgData.timestamp\n  }\n}];"
        }
      },
