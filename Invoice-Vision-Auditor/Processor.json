      {
        "parameters": {
          "jsCode": "const d = $('Check for Duplicate').first().json;\nconst fileId = d.file_id || $input.first().json.id || '';\nconst driveUrl = 'https://drive.google.com/file/d/' + fileId + '/view';\nconst confidence = Math.round((d.confidence_score||0)*100);\nconst amount = (d.total_amount!==null&&d.total_amount!==undefined)?(d.currency||'')+' '+d.total_amount:'Not found';\nconst dupLabel = d.is_duplicate?' [DUPLICATE]':'';\nconst errRows = (d.errors||[]).map(e=>'<li style=\"color:#c04828;margin:4px 0\">'+e+'</li>').join('');\nconst warnRows = (d.warnings||[]).length?'<p><b>Warnings:</b></p><ul>'+(d.warnings||[]).map(w=>'<li style=\"color:#e67e22;margin:4px 0\">'+w+'</li>').join('')+'</ul>':'';\nconst html = '<div style=\"font-family:Arial,sans-serif;max-width:580px\"><div style=\"background:#c04828;padding:18px 24px;border-radius:8px 8px 0 0\"><h2 style=\"color:#fff;margin:0;font-size:16px\">Invoice Flagged'+dupLabel+'</h2></div><div style=\"padding:20px 24px;border:1px solid #ddd;border-top:none\"><table style=\"width:100%\"><tr><td style=\"color:#666;padding:4px 12px 4px 0\">File</td><td style=\"font-weight:700\">'+(d.file_name||'Unknown')+'</td></tr><tr><td style=\"color:#666;padding:4px 12px 4px 0\">Vendor</td><td>'+(d.vendor_name||'Not identified')+'</td></tr><tr><td style=\"color:#666;padding:4px 12px 4px 0\">Invoice #</td><td>'+(d.invoice_number||'Not found')+'</td></tr><tr><td style=\"color:#666;padding:4px 12px 4px 0\">Amount</td><td>'+amount+'</td></tr><tr><td style=\"color:#666;padding:4px 12px 4px 0\">AI Confidence</td><td>'+confidence+'%</td></tr></table><p><b>Problems found:</b></p><ul>'+errRows+'</ul>'+warnRows+'<p><a href=\"'+driveUrl+'\" style=\"display:inline-block;background:#0f6e56;color:#fff;padding:10px 20px;text-decoration:none;border-radius:6px\">Open in Google Drive</a></p><p style=\"font-size:11px;color:#aaa\">Processed: '+d.processed_at+'</p></div></div>';\nreturn [{json:{subject:(d.is_duplicate?'[DUPLICATE] ':'[FLAGGED] ')+(d.file_name||'Invoice'),html}}];"
        },
