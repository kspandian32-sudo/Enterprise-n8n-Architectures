{
  "name": "n8n-nodes-gemini-pdf-analyzer",
  "version": "1.0.0",
  "description": "n8n community node that uses Google Gemini Vision to analyze PDF documents and extract structured data (invoices, contracts, reports).",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "gemini",
    "pdf",
    "ai",
    "vision",
    "invoice",
    "ocr"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kspandian32-sudo/Enterprise-n8n-Architectures",
  "author": {
    "name": "Pandian K S",
    "email": "kspandia@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kspandian32-sudo/Enterprise-n8n-Architectures.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run copy-icons",
    "copy-icons": "copyfiles -u 2 nodes/**/*.svg dist/",
    "dev": "tsc --watch",
    "format": "prettier src --write",
    "lint": "eslint nodes credentials",
    "prepublishOnly": "npm run build && npm run lint",
    "test": "vitest run"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GeminiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GeminiPdfAnalyzer/GeminiPdfAnalyzer.node.js"
    ]
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@vitest/coverage-v8": "^4.1.5",
    "copyfiles": "^2.4.1",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.10",
    "npm": ">=8.19.0"
  }
}
