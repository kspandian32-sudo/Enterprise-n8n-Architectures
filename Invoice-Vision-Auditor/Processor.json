        "id": "8513af5e-1f6a-428f-95b6-7280d0f52557",
        "name": "PDF to Base64",
        "type": "n8n-nodes-base.extractFromFile",
        "typeVersion": 1,
        "position": [
          -160,
          528
        ]
      },
      {
        "parameters": {
          "jsCode": "const base64Data   = $input.first().json.base64data;\nconst triggerData  = $('New Invoice in Drive').first().json;\nconst fileName     = triggerData.name || 'unknown.pdf';\nconst fileId       = triggerData.id   || '';\nconst prompt = 'You are an invoice auditor. Analyze this invoice PDF.\\nReturn ONLY a raw JSON object with no markdown and no code fences.\\nFields: vendor_name (string or null), invoice_number (string or null), invoice_date (YYYY-MM-DD or null), due_date (YYYY-MM-DD or null), line_items_count (integer or null), total_amount (number or null), currency (3-letter ISO code or null), has_signature (boolean), signature_valid (boolean - true ONLY for handwritten ink or rubber stamp not printed names), confidence_score (float 0.0 to 1.0), errors (array - include: No signature found, Total amount missing, Not a valid invoice, Invoice number missing - whichever apply), warnings (array - include: Due date has passed, Currency unclear - whichever apply). Return ONLY the JSON.';\nconst payload = { contents: [{ parts: [{ inline_data: { mime_type: 'application/pdf', data: base64Data } }, { text: prompt }] }], generationConfig: { temperature: 0.0, maxOutputTokens: 2048 } };\nreturn [{ json: { payload, file_name: fileName, file_id: fileId } }];"
        },
        "id": "a619216d-12a9-4361-bc34-44c23f30de01",
        "name": "Build Gemini Payload",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          64,
          528
        ]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpQueryAuth",
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ JSON.stringify($json.payload) }}",
          "options": {
            "timeout": 90000
          }
        },
        "id": "3e12ef91-8321-498c-baa3-130b2457a40e",
        "name": "Analyze with Gemini",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          288,
          528
        ],
        "retryOnFail": true,
        "maxTries": 3,
        "waitBetweenTries": 5000,
        "credentials": {
          "httpQueryAuth": {
            "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID",
            "name": "Query Auth Account"
          }
        },
        "onError": "continueRegularOutput"
      },
      {
        "parameters": {
          "jsCode": "const geminiOutput = $input.first().json;\nconst fileMeta     = $('Build Gemini Payload').first().json;\nlet parsed;\ntry {\n  if (!geminiOutput || !geminiOutput.candidates || !geminiOutput.candidates[0]) {\n    throw new Error('Invalid Gemini response structure');\n  }\n  const raw   = geminiOutput.candidates[0].content.parts[0].text;\n  const start = raw.indexOf('{'); const end = raw.lastIndexOf('}');\n  if (start === -1 || end === -1) throw new Error('No JSON in response');\n  parsed = JSON.parse(raw.slice(start, end + 1));\n} catch (e) {\n  parsed = { \n    vendor_name: null, \n    invoice_number: null, \n    invoice_date: null, \n    due_date: null, \n    line_items_count: null, \n    total_amount: null, \n    currency: null, \n    has_signature: false, \n    signature_valid: false, \n    confidence_score: 0.0, \n    errors: ['AI parse failure: ' + e.message], \n    warnings: [] \n  };\n}\nreturn [{ json: { \n  file_name: String(fileMeta.file_name||''), \n  file_id: String(fileMeta.file_id||''), \n  vendor_name: parsed.vendor_name||null, \n  invoice_number: String(parsed.invoice_number||''), \n  invoice_date: parsed.invoice_date||null, \n  due_date: parsed.due_date||null, \n  line_items_count: parsed.line_items_count||null, \n  total_amount: (parsed.total_amount!==undefined&&parsed.total_amount!==null)?Number(parsed.total_amount):null, \n  currency: parsed.currency||null, \n  has_signature: Boolean(parsed.has_signature), \n  signature_valid: Boolean(parsed.signature_valid), \n  confidence_score: Math.min(1,Math.max(0,Number(parsed.confidence_score)||0)), \n  errors: Array.isArray(parsed.errors)?parsed.errors:[], \n  warnings: Array.isArray(parsed.warnings)?parsed.warnings:[], \n  processed_at: new Date().toISOString(), \n  source: 'auto' \n} }];"
        },
